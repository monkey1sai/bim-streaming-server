# All folders starting with _ are local.
_*/

# Compiled python files.
*.py[cod]
*.pyc
__pycache__/

# Visual Studio files.
/.vs
**/.vscode/ipch

# macOS files.
.DS_Store

# Generated license file.
PACKAGE-DEPS.yaml

# packman .user config
*.packman.xml.user

# kit user config
deps/**/user.toml

# vscode settings are copied and filled in from 'settings.json.template'
.vscode/settings.json

# PyCharm files.
/.idea/

# Linux in docker build $HOME dirs
/.nvidia-omniverse
/.local
/.cache

# Omniverse EULA breadcrumb
/.omniverse_eula_accepted.txt

# Streaming EventTrace
*.etli
*.etl

# Keep generated template metadata out of version control, but track app/extension sources.
/source/*
!/source/apps/
!/source/apps/**
!/source/extensions/
!/source/extensions/**
/source/**/__pycache__/
/source/**/__pycache__/**
/source/**/*.pyc
/source/rendered_template_metadata.json

.gitnexus

# Local agent / browser automation artifacts
/.claude/
/.playwright-mcp/
/AGENTS.md
/CLAUDE.md
/current-stream-*.png
